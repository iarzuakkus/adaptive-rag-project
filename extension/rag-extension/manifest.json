{
  "manifest_version": 3,
  "name": "Adaptive RAG",
  "version": "1.0.0",
  "description": "Web sayfalarını kazıyıp Python backend'e gönderen Chrome extension.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "Adaptive RAG",
    "default_icon": {
      "64": "assets/logo64.png",
      "128": "assets/logo128.png"
    }
  },
  "icons": {
    "64": "assets/logo64.png",
    "128": "assets/logo128.png"
  },
  "background": {
    "service_worker": "core/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/logo.svg",
        "assets/logo64.png",
        "assets/logo128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "scraping/text-utils.js",
        "scraping/dom-cleaner.js",
        "scraping/block-utils.js",
        "scraping/extractor.js",

        "scraping/cleaner/cleaner-text-utils.js",
        "scraping/cleaner/cleaner-chunks.js",
        "scraping/cleaner/cleaner-scoring.js",
        "scraping/cleaner/cleaner-blocks.js",
        "scraping/cleaner/cleaner-page.js",

        "scraping/cleaner/cleaner-entry.js",

        "scraping/content.js",

        "core/session-store.js"
      ],
      "run_at": "document_idle"
    }
  ]
}