{
  "manifest_version": 3,
  "name": "MemorAI",
  "version": "1.0.0",
  "description": "Kişisel araştırma asistanı",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "MemorAI",
    "default_icon": {
      "64": "assets/logo64.png",
      "128": "assets/logo128.png"
    }
  },
  "icons": {
    "64": "assets/logo64.png",
    "128": "assets/logo128.png"
  },
  "background": {
    "service_worker": "core/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/logo.svg",
        "assets/logo64.png",
        "assets/logo128.png",
        "assets/fonts/albertusnova.otf",

        "icons/source.svg",
        "icons/recommendation.svg",
        "icons/scan.svg",
        "icons/refresh.svg",
        "icons/external-link.svg",
        "icons/rubbish.svg",

        "icons/note.svg",
        "icons/personal-note.svg",
        "icons/file-text.svg",
        "icons/download.svg",
        "icons/save.svg",
        "icons/edit.svg",
        "icons/folder.svg",
        "icons/check.svg",
        "icons/info.svg",
        "icons/clock.svg",
        "icons/file-pdf.svg",
        "icons/link.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core/session-store.js",
        "core/scan-settings-store.js",
        "core/research-store.js",
        "core/notes-store.js",

        "scraping/text-utils.js",
        "scraping/dom-cleaner.js",
        "scraping/block-utils.js",
        "scraping/extractor.js",

        "scraping/cleaner/cleaner-text-utils.js",
        "scraping/cleaner/cleaner-chunks.js",
        "scraping/cleaner/cleaner-scoring.js",
        "scraping/cleaner/cleaner-blocks.js",
        "scraping/cleaner/cleaner-page.js",
        "scraping/cleaner/cleaner-entry.js",

        "scraping/page-scan-rules.js",
        "scraping/scan-prompt.js",
        "scraping/content.js",

        "ui/widget/widget-state.js",

        "ui/widget/events/chat-events.js",
        "ui/widget/events/recommendation-events.js",
        "ui/widget/events/source-events.js",
        "ui/widget/events/highlight-events.js",
        "ui/widget/events/note-detail-events.js",
        "ui/widget/events/note-events.js",

        "ui/widget/render/widget-shell.js",
        "ui/widget/render/chat-tab.js",
        "ui/widget/render/recommendations-panel.js",
        "ui/widget/render/sources-tab.js",
        "ui/widget/render/source-detail.js",
        "ui/widget/render/note-detail.js",
        "ui/widget/render/notes-tab.js",

        "ui/widget/widget.js"
      ],
      "css": [
        "ui/widget/styles/widget-variables.css",
        "ui/widget/styles/widget-launcher.css",
        "ui/widget/styles/widget-layout.css",
        "ui/widget/styles/widget-tabs.css",
        "ui/widget/styles/widget-cards.css",
        "ui/widget/styles/widget-chat.css",
        "ui/widget/styles/widget-sources.css",
        "ui/widget/styles/widget-recommendations.css",
        "ui/widget/styles/widget-source-detail.css",
        "ui/widget/styles/widget-notes.css",
        "ui/widget/styles/widget-note-detail.css",
        "ui/widget/styles/widget-effects.css"
      ],
      "run_at": "document_idle"
    }
  ]
}